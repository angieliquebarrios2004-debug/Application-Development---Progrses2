import 'package:flutter/material.dart';
import '../services/firestore_service.dart';
import '../models/reservist.dart';
import '../models/promotion_package.dart';

class CreatePromotionPackageScreen extends StatefulWidget {
  const CreatePromotionPackageScreen({super.key});

  @override
  State<CreatePromotionPackageScreen> createState() =>
      _CreatePromotionPackageScreenState();
}

class _CreatePromotionPackageScreenState
    extends State<CreatePromotionPackageScreen> {
  final FirestoreService _firestoreService = FirestoreService();

  Reservist? _selectedReservist;
  String? _selectedTargetRank;
  bool _isLoading = false;

  final Map<String, List<String>> _promotionPaths = {
    'Pvt': ['PFC'],
    'PFC': ['Cpl'],
    'Cpl': ['Sgt'],
    'Sgt': ['SSgt'],
    'SSgt': ['TSgt'],
    'TSgt': ['MSgt'],
    'MSgt': ['1SG', 'SGM', 'CSM'],
    '2LT': ['1LT'],
    '1LT': ['CPT'],
    'CPT': ['MAJ'],
    'MAJ': ['LTC'],
    'LTC': ['COL'],
  };

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFFF5F4F0),
      appBar: AppBar(
        title: const Text(
          'Create Promotion Package',
          style: TextStyle(fontWeight: FontWeight.bold),
        ),
        backgroundColor: const Color(0xFF0A1628),
        foregroundColor: Colors.white,
        elevation: 0,
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            _buildReservistSelector(),
            const SizedBox(height: 24),
            if (_selectedReservist != null && _selectedTargetRank != null) ...[
              _buildTargetRankSelector(),
              const SizedBox(height: 24),
              _buildPackageSummary(),
              const SizedBox(height: 32),
              _buildCreateButton(),
            ] else if (_selectedReservist != null) ...[
              _buildTargetRankSelector(),
              const SizedBox(height: 24),
              const SizedBox(height: 32),
              _buildCreateButton(),
            ],
          ],
        ),
      ),
    );
  }

  Widget _buildReservistSelector() {
    return StreamBuilder<List<Reservist>>(
      stream: _firestoreService.getReservists(),
      builder: (context, snapshot) {
        if (!snapshot.hasData) {
          return const Center(child: CircularProgressIndicator());
        }

        final reservists = snapshot.data!;
        final eligibleReservists =
            reservists.where((r) => r.eligibilityStatus == 'Eligible').toList();

        return Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text(
              'Select Reservist',
              style: TextStyle(
                fontSize: 16,
                fontWeight: FontWeight.bold,
                color: Color(0xFF0A1628),
              ),
            ),
            const SizedBox(height: 8),
            Container(
              decoration: BoxDecoration(
                color: Colors.white,
                borderRadius: BorderRadius.circular(12),
                border: Border.all(color: const Color(0xFFD4CFC4)),
              ),
              child: InkWell(
                onTap: () => _showReservistDialog(eligibleReservists),
                borderRadius: BorderRadius.circular(12),
                child: Padding(
                  padding: const EdgeInsets.all(16),
                  child: Row(
                    mainAxisAlignment: MainAxisAlignment.spaceBetween,
                    children: [
                      Expanded(
                        child: _selectedReservist == null
                            ? const Text(
                                'Select a reservist',
                                style: TextStyle(color: Color(0xFF6B7280)),
                              )
                            : Column(
                                crossAxisAlignment: CrossAxisAlignment.start,
                                children: [
                                  Text(
                                    _selectedReservist!.fullName,
                                    style: const TextStyle(
                                      fontWeight: FontWeight.bold,
                                      fontSize: 14,
                                    ),
                                  ),
                                  const SizedBox(height: 4),
                                  Text(
                                    '${_selectedReservist!.rank} | ${_selectedReservist!.serialNumber}',
                                    style: const TextStyle(
                                      fontSize: 12,
                                      color: Color(0xFF6B7280),
                                    ),
                                  ),
                                ],
                              ),
                      ),
                      const Icon(Icons.arrow_drop_down,
                          color: Color(0xFF6B7280)),
                    ],
                  ),
                ),
              ),
            ),
            if (eligibleReservists.isEmpty)
              Container(
                padding: const EdgeInsets.all(16),
                decoration: BoxDecoration(
                  color: Colors.white,
                  borderRadius: BorderRadius.circular(12),
                  border: Border.all(color: const Color(0xFFD4CFC4)),
                ),
                child: const Center(
                  child: Text(
                    'No eligible reservists found',
                    style: TextStyle(color: Color(0xFF6B7280)),
                  ),
                ),
              ),
          ],
        );
      },
    );
  }

  void _showReservistDialog(List<Reservist> reservists) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Select Reservist'),
        content: SizedBox(
          width: double.maxFinite,
          height: 400,
          child: ListView.builder(
            itemCount: reservists.length,
            itemBuilder: (context, index) {
              final reservist = reservists[index];
              return ListTile(
                title: Text(reservist.fullName),
                subtitle: Text('${reservist.rank} | ${reservist.serialNumber}'),
                onTap: () {
                  setState(() {
                    _selectedReservist = reservist;
                    _selectedTargetRank = null;
                  });
                  Navigator.pop(context);
                },
              );
            },
          ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancel'),
          ),
        ],
      ),
    );
  }

  Widget _buildTargetRankSelector() {
    if (_selectedReservist == null) return const SizedBox.shrink();

    final possibleRanks = _promotionPaths[_selectedReservist!.rank] ?? [];

    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        const Text(
          'Target Rank',
          style: TextStyle(
            fontSize: 16,
            fontWeight: FontWeight.bold,
            color: Color(0xFF0A1628),
          ),
        ),
        const SizedBox(height: 8),
        Wrap(
          spacing: 8,
          runSpacing: 8,
          children: possibleRanks.map((rank) {
            return ChoiceChip(
              label: Text(rank),
              selected: _selectedTargetRank == rank,
              onSelected: (selected) {
                setState(() {
                  _selectedTargetRank = selected ? rank : null;
                });
              },
              selectedColor: const Color(0xFF0A1628),
              labelStyle: TextStyle(
                color: _selectedTargetRank == rank
                    ? Colors.white
                    : const Color(0xFF0A1628),
              ),
            );
          }).toList(),
        ),
      ],
    );
  }

  Widget _buildPackageSummary() {
    // Add null check to prevent errors
    if (_selectedReservist == null || _selectedTargetRank == null) {
      return const SizedBox.shrink();
    }

    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: const Color(0xFFD4CFC4)),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          const Text(
            'Package Summary',
            style: TextStyle(
              fontSize: 14,
              fontWeight: FontWeight.bold,
              color: Color(0xFF0A1628),
            ),
          ),
          const SizedBox(height: 12),
          _buildSummaryRow('Reservist', _selectedReservist!.fullName),
          const SizedBox(height: 12),
          _buildSummaryRow('Current Rank', _selectedReservist!.rank),
          const SizedBox(height: 12),
          _buildSummaryRow('Target Rank', _selectedTargetRank!),
          const SizedBox(height: 12),
          _buildSummaryRow('Unit', _selectedReservist!.unit),
          const SizedBox(height: 12),
          _buildSummaryRow(
            'Application Date',
            '${DateTime.now().month}/${DateTime.now().day}/${DateTime.now().year}',
          ),
        ],
      ),
    );
  }

  Widget _buildSummaryRow(String label, String value) {
    return Row(
      mainAxisAlignment: MainAxisAlignment.spaceBetween,
      children: [
        Text(
          label,
          style: const TextStyle(
            fontSize: 13,
            color: Color(0xFF6B7280),
          ),
        ),
        Flexible(
          child: Text(
            value,
            style: const TextStyle(
              fontSize: 13,
              fontWeight: FontWeight.w500,
              color: Color(0xFF0A1628),
            ),
            textAlign: TextAlign.right,
          ),
        ),
      ],
    );
  }

  Widget _buildCreateButton() {
    bool isDisabled =
        _selectedReservist == null || _selectedTargetRank == null || _isLoading;

    return SizedBox(
      width: double.infinity,
      child: ElevatedButton(
        onPressed: isDisabled ? null : _createPackage,
        style: ElevatedButton.styleFrom(
          backgroundColor: const Color(0xFF0A1628),
          foregroundColor: Colors.white,
          padding: const EdgeInsets.symmetric(vertical: 16),
          shape: RoundedRectangleBorder(
            borderRadius: BorderRadius.circular(12),
          ),
        ),
        child: _isLoading
            ? const SizedBox(
                height: 20,
                width: 20,
                child: CircularProgressIndicator(
                  strokeWidth: 2,
                  valueColor: AlwaysStoppedAnimation<Color>(Colors.white),
                ),
              )
            : const Text(
                'Create Promotion Package',
                style: TextStyle(
                  fontSize: 16,
                  fontWeight: FontWeight.bold,
                ),
              ),
      ),
    );
  }

  Future<void> _createPackage() async {
    if (_selectedReservist == null || _selectedTargetRank == null) return;

    setState(() => _isLoading = true);

    try {
      final requirements =
          PromotionRequirements.getAllRequirements(_selectedReservist!.rank);

      Map<String, DocumentStatus> documents = {};
      for (var req in requirements) {
        documents[req] = DocumentStatus(isUploaded: false);
      }

      final now = DateTime.now();

      final package = PromotionPackage(
        id: '',
        reservistId: _selectedReservist!.id,
        reservistName: _selectedReservist!.fullName,
        currentRank: _selectedReservist!.rank,
        targetRank: _selectedTargetRank!,
        applicationDate: now,
        documents: documents,
        status: 'Pending',
        createdAt: now,
        updatedAt: now,
      );

      await _firestoreService.addPromotionPackage(package);

      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text('Promotion package created successfully!'),
            backgroundColor: Color(0xFF22C55E),
          ),
        );
        Navigator.pop(context, true);
      }
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Error creating package: $e'),
            backgroundColor: const Color(0xFFF87171),
          ),
        );
      }
    } finally {
      if (mounted) {
        setState(() => _isLoading = false);
      }
    }
  }
}
